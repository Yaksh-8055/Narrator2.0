# =============================================================================
# Story Narrator - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Rename: cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Google Gemini - Story Generation
# -----------------------------------------------------------------------------
# Get your API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# IBM Watson Text-to-Speech (TTS)
# -----------------------------------------------------------------------------
# Get from: IBM Cloud → Text to Speech → Service Credentials
IBM_TTS_API_KEY=your_ibm_tts_api_key_here
IBM_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com

# -----------------------------------------------------------------------------
# IBM Cloudant - Database
# -----------------------------------------------------------------------------
# Get from: IBM Cloud → Cloudant → Service Credentials
# URL format: https://<instance>.cloudantnosqldb.appdomain.cloud
CLOUDANT_URL=https://your-instance.cloudantnosqldb.appdomain.cloud
CLOUDANT_API_KEY=your_cloudant_api_key_here

# -----------------------------------------------------------------------------
# IBM App ID - Authentication
# -----------------------------------------------------------------------------
# Get from: IBM Cloud → App ID → Applications → Your App → Credentials
# Enable "Resource Owner Password" flow in app settings
APPID_CONFIG={"clientId":"your_client_id","secret":"your_client_secret","tenantId":"your_tenant_id","url":"https://your-region.appid.cloud.ibm.com"}