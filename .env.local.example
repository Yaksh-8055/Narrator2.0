# ─────────────────────────────────────────────────────────────────────────────
# Story Narrator — Environment Variables Template
# Copy this file to .env.local and fill in your real credentials.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Google Gemini ─────────────────────────────────────────────────────────────
# Used for: AI story generation (lib/gemini.ts)
# Get your key: https://aistudio.google.com/app/apikey
# Model used: gemini-1.5-pro
GEMINI_API_KEY=your-gemini-api-key-here


# ── IBM Watson Text-to-Speech ─────────────────────────────────────────────────
# Used for: Story narration / voice synthesis (lib/ibmtts.ts)
# Lite plan: 10,000 characters/month free — no credit card required
#
# How to get credentials:
#   1. Go to https://cloud.ibm.com/catalog/services/text-to-speech
#   2. Select the "Lite" plan → Create
#   3. Open the service → Manage → Credentials → New credential
#   4. Copy the "apikey" and "url" values from the generated JSON
#
# IBM_TTS_URL format: https://api.<region>.text-to-speech.watson.cloud.ibm.com
# Common regions: us-south, eu-gb, eu-de, au-syd, jp-tok
IBM_TTS_API_KEY=your-ibm-watson-tts-api-key-here
IBM_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com


# ── IBM Cloudant NoSQL Database ───────────────────────────────────────────────
# Used for: Storing and retrieving user stories (lib/cloudant.ts)
# The app auto-creates a "stories" database on first run.
#
# How to get credentials:
#   1. Go to https://cloud.ibm.com/catalog/services/cloudant
#   2. Select "Lite" plan (1 GB free) → Create
#   3. Open the service → Service credentials → New credential (role: Manager)
#   4. Copy "url" → CLOUDANT_URL
#   5. Copy "apikey" → CLOUDANT_API_KEY
#
# CLOUDANT_URL format: https://<instance-uuid>-bluemix.cloudant.com
CLOUDANT_URL=https://your-instance.cloudant.com
CLOUDANT_API_KEY=your-cloudant-iam-api-key-here


# ── IBM App ID (Authentication) ───────────────────────────────────────────────
# Used for: User login, JWT token issuance and validation (lib/appid.ts)
# This is a JSON string — paste the whole object as one line.
#
# How to get credentials:
#   1. Go to https://cloud.ibm.com/catalog/services/app-id
#   2. Create the service (Lite: 1,000 events/month free)
#   3. Open the service → Applications → Add application
#   4. Note the "oauthServerUrl", "clientId", and "secret"
#   5. Enable "Resource owner password" grant type under the application settings
#
# IMPORTANT: The ROPC (Resource Owner Password Credentials) grant MUST be
# enabled in your App ID application for the login flow to work.
#
# Format: single-line JSON string
APPID_CONFIG={"oauthServerUrl":"https://us-south.appid.cloud.ibm.com/oauth/v4/your-tenant-id","clientId":"your-client-id","secret":"your-client-secret"}


# ─────────────────────────────────────────────────────────────────────────────
# REMOVED (ElevenLabs — replaced by IBM Watson TTS):
#   ELEVENLABS_API_KEY  ← no longer used
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# SUMMARY OF ALL REQUIRED KEYS (6 values across 4 variables):
#
#   GEMINI_API_KEY      — 1 value
#   IBM_TTS_API_KEY     — 1 value   ← IBM Watson TTS
#   IBM_TTS_URL         — 1 value   ← IBM Watson TTS service URL
#   CLOUDANT_URL        — 1 value
#   CLOUDANT_API_KEY    — 1 value
#   APPID_CONFIG        — 1 JSON string (contains oauthServerUrl, clientId, secret)
# ─────────────────────────────────────────────────────────────────────────────
